@startuml containers
!$NEW_C4_STYLE = 1
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

System_Ext(edge, "Datum Edge", "Anycast LB, WAF, rate limiting, DDoS protection")
System_Ext(gvpc, "Galactic VPC Fabric", "SRv6-based overlay network with path computation engine")

System_Boundary(worker_boundary, "Worker Node") {
    Container(dpu, "BlueField DPU", "DOCA / eBPF", "Hardware eSwitch, XDP on ARM cores, packet steering")
    Container(ovs, "OVS Bridge", "Open vSwitch", "Software bridge with hardware flow offload to eSwitch")
    Container(wake_daemon, "Wake Daemon", "", "Receives wake signals from eBPF, triggers instance lifecycle")
    Container(instance, "Instance", "Function / Container / VM", "Single deployment of a workload, attached to gVPC network interface")
}

Rel_D(edge, gvpc, "Routes traffic into", "SRv6 encap")
Rel_R(gvpc, dpu, "Delivers to worker", "SRv6 decap")
Rel_D(dpu, ovs, "Offloads flow rules", "eSwitch hardware")
Rel_L(ovs, instance, "Forwards via TAP", "standard class")
Rel_D(dpu, instance, "Steers to VF", "performance class")
Rel_R(dpu, wake_daemon, "Signals wake", "BPF ring buffer")
Rel_D(wake_daemon, instance, "Starts/resumes", "VMM API")

SHOW_LEGEND()
@enduml
